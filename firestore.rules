rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles Security
    match /users/{userId} {
      allow read, update: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Lifetime preservation: deletion strictly forbidden
    }
    
    // Shortened Links Security
    match /links/{linkId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Click Analytics Logs Security
    match /clicks_analytics/{analyticId} {
      allow create: if true; // Public visitors generate impression telemetry
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow update, delete: if false; // Immutable analytics history
    }
  }
}
